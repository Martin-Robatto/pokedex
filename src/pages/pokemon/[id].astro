---
import type { GetStaticPaths } from 'astro';
import { pokemonDetailsZoomAnimation } from '../../animations/pokemon-details-transition';
import '../../animations/pokemon-details-transition.css';
import Layout from '@layout/layout.astro';
import { getPokemonById, getPokemonList } from '../../services/pokemon.service';

export const getStaticPaths = (async () => {
	const data = await getPokemonList();

	return data.results.map((pokemon) => {
		// Extract ID from URL like "https://pokeapi.co/api/v2/pokemon/25/"
		const id = pokemon.url.split('/').filter(Boolean).pop();
		return {
			params: { id },
		};
	});
}) satisfies GetStaticPaths;

const { id } = Astro.params;

if (!id) {
	throw new Error('Pokemon id is required');
}

const pokemon = await getPokemonById(id);
const imageUrl =
	pokemon.sprites.other['official-artwork'].front_default ??
	pokemon.sprites.front_default ??
	'/favicon.svg';
const audioUrl = `https://raw.githubusercontent.com/PokeAPI/cries/main/cries/pokemon/latest/${pokemon.id}.ogg`;
---

<Layout title={`${pokemon.name} | Pokemon`}>
	<main class="my-6">
		<a
			href="/"
			class="mb-4 inline-block rounded-md border border-slate-600 px-3 py-1 text-sm hover:bg-slate-700"
		>
			Back
		</a>

		<section
			transition:name={`card-${pokemon.id}`}
			transition:animate={pokemonDetailsZoomAnimation}
			class="rounded-xl border border-slate-600 bg-slate-700 p-6 text-center shadow-lg"
		>
			<img
				transition:name={`image-${pokemon.id}`}
				src={imageUrl}
				alt={pokemon.name}
				class="mx-auto h-56 w-56 object-contain"
				loading="lazy"
				decoding="async"
			/>

			<h1 transition:name={`title-${pokemon.id}`} class="mt-3 text-3xl font-bold capitalize">
				{pokemon.name}
			</h1>
			<p class="mt-1 text-slate-300">#{pokemon.id}</p>
			<audio controls class="mx-auto mt-4">
				<source src={audioUrl} type="audio/ogg" />
				Your browser does not support the audio element.
			</audio>

			<div class="mt-6 grid gap-3 text-left sm:grid-cols-3">
				<div class="rounded-lg border border-slate-500 bg-slate-800 p-3">
					<p class="text-xs uppercase text-slate-400">Height</p>
					<p class="mt-1 text-lg font-semibold">{pokemon.height}</p>
				</div>
				<div class="rounded-lg border border-slate-500 bg-slate-800 p-3">
					<p class="text-xs uppercase text-slate-400">Weight</p>
					<p class="mt-1 text-lg font-semibold">{pokemon.weight}</p>
				</div>
				<div class="rounded-lg border border-slate-500 bg-slate-800 p-3">
					<p class="text-xs uppercase text-slate-400">Types</p>
					<p class="mt-1 text-lg font-semibold capitalize">
						{pokemon.types.map((entry) => entry.type.name).join(', ')}
					</p>
				</div>
			</div>
		</section>
	</main>
</Layout>
