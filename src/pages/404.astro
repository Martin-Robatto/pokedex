---
import Layout from '@layout/layout.astro';
---

<Layout title='404 | Pokemon'>
	<main class="flex min-h-[70vh] flex-col items-center justify-center px-4 text-center">
		<p class="text-sm font-semibold uppercase tracking-widest text-slate-400">Error 404</p>
		<h1 class="mt-3 text-4xl font-bold sm:text-5xl">Page not found</h1>
		<p class="mt-4 max-w-md text-slate-300">
			The page you are trying to visit does not exist or may have been moved.
		</p>
		<a
			href="/"
			class="mt-8 inline-block rounded-md border border-slate-500 bg-slate-700 px-4 py-2 font-medium transition-colors hover:bg-slate-600"
		>
			Go back home
		</a>
	</main>
</Layout>
